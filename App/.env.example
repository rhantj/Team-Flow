# ===== 공통 (docker-compose / backend_spring / backend_fastAPI 에서 사용) =====
# 아래 값들은 로컬 개발용 예시다. 서버(OCI 등)에 배포할 때는 반드시 실제 값으로 바꿀 것 —
# 특히 POSTGRES_PASSWORD, JWT_SECRET을 예시 그대로 쓰면 안 된다.
POSTGRES_DB=workflow
POSTGRES_USER=postgres
POSTGRES_PASSWORD=root
DATABASE_URL=postgresql://postgres:root@localhost:5432/workflow
# 로컬에 5432를 이미 쓰는 PostgreSQL이 있다면 아래 두 줄의 주석을 풀고 포트를 바꿔서 쓸 것
# (DATABASE_URL의 포트도 같이 맞춰줘야 함)
# DB_HOST_PORT=5433

REDIS_URL=redis://localhost:6379/0

KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ===== backend_spring (Spring Boot) =====
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-bytes

# Google Cloud Console > APIs & Services > Credentials 에서 OAuth 2.0 클라이언트 ID(웹 애플리케이션) 발급.
# 승인된 리디렉션 URI에 아래 GOOGLE_REDIRECT_URI 값을 그대로 등록할 것.
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8080/api/v1/auth/google/callback
# OAuth 콜백 처리 후 브라우저를 리다이렉트시킬 프론트엔드 주소
WORKFLOW_FRONTEND_BASE_URL=http://localhost:5173

# ===== backend_fastAPI (FastAPI) =====
LLM_API_KEY=sk-your-llm-api-key
